#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
compose_root="$(cd "$repo_root/.." && pwd)"

echo "Running business-fe Docker compose before push from ${repo_root}..."
docker rm -f \
  coachly-users-be \
  coachly-workouts-be \
  coachly-exercises-be \
  coachly-feedback-be \
  coachly-coach-be \
  coachly-api-gateway \
  coachly-business-fe >/dev/null 2>&1 || true

docker compose -f "$compose_root/docker-compose.yml" --profile business-fe up --build -d coachly-business-fe
